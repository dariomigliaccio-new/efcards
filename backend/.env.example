# ─── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
CLIENT_URL=http://localhost:3000

# ─── Database ──────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=cardmatch_user
DB_PASS=your_secure_password
DB_NAME=cardmatch

# ─── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_min_32_chars
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# ─── Google OAuth ──────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:4000/api/auth/google/callback

# ─── Apple OAuth ───────────────────────────────────────────────────────────────
APPLE_CLIENT_ID=your.apple.client.id
APPLE_TEAM_ID=YOUR_TEAM_ID
APPLE_KEY_ID=YOUR_KEY_ID
APPLE_PRIVATE_KEY_PATH=./config/apple_auth_key.p8
APPLE_CALLBACK_URL=http://localhost:4000/api/auth/apple/callback

# ─── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
PLATFORM_FEE_PERCENT=0.08

# ─── Email (SMTP) ───────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@cardmatch.io
SMTP_PASS=your_app_password
EMAIL_FROM="CardMatch <noreply@cardmatch.io>"

# ─── Storage (optional — local by default) ─────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=10
